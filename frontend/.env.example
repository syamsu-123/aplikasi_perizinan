# Backend API URL - Example Configuration
# Copy this file to .env and update with your computer's IP address
# To find your IP: run `ipconfig` in terminal, look for IPv4 Address
#
# For development (localhost):
# VITE_API_URL=http://localhost:5000/api
#
# For Android device on same WiFi:
# VITE_API_URL=http://192.168.1.X:5000/api
